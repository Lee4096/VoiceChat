<mxfile host="app.diagrams.net">
  <diagram name="VoiceChat Architecture" id="voicechat-arch">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="800">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Client Layer -->
        <mxCell id="client-bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e3f2fd;strokeColor=#1976d2;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="50" y="50" width="300" height="200" as="geometry" />
        </mxCell>
        <mxCell id="client-label" value="客户端" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontStyle=1;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="60" y="55" width="80" height="20" as="geometry" />
        </mxCell>

        <!-- Browser -->
        <mxCell id="browser" value="浏览器&#xa;(React + Vite)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="80" y="90" width="120" height="50" as="geometry" />
        </mxCell>

        <!-- WebRTC -->
        <mxCell id="webrtc" value="WebRTC" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff3e0;strokeColor=#ff9800;" vertex="1" parent="1">
          <mxGeometry x="220" y="90" width="100" height="50" as="geometry" />
        </mxCell>

        <!-- Mobile App -->
        <mxCell id="mobile" value="移动端 App" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="80" y="160" width="240" height="50" as="geometry" />
        </mxCell>

        <!-- Gateway Layer -->
        <mxCell id="gateway-bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f5e9;strokeColor=#388e3c;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="400" y="50" width="400" height="300" as="geometry" />
        </mxCell>
        <mxCell id="gateway-label" value="API 网关层" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontStyle=1;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="410" y="55" width="100" height="20" as="geometry" />
        </mxCell>

        <!-- Nginx -->
        <mxCell id="nginx" value="Nginx&#xa;(反向代理/负载均衡)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="430" y="90" width="140" height="50" as="geometry" />
        </mxCell>

        <!-- HTTP API -->
        <mxCell id="http-api" value="HTTP API&#xa;(Gin)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="590" y="90" width="120" height="50" as="geometry" />
        </mxCell>

        <!-- WebSocket -->
        <mxCell id="websocket" value="WebSocket&#xa;(Gorilla)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="430" y="180" width="120" height="50" as="geometry" />
        </mxCell>

        <!-- Signalling -->
        <mxCell id="signalling" value="信令服务&#xa;(WebRTC)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff3e0;strokeColor=#ff9800;" vertex="1" parent="1">
          <mxGeometry x="590" y="180" width="120" height="50" as="geometry" />
        </mxCell>

        <!-- Auth -->
        <mxCell id="auth" value="JWT 认证&#xa;OAuth2" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fce4ec;strokeColor=#c2185b;" vertex="1" parent="1">
          <mxGeometry x="430" y="270" width="280" height="50" as="geometry" />
        </mxCell>

        <!-- Service Layer -->
        <mxCell id="service-bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff3e0;strokeColor=#f57c00;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="400" y="380" width="400" height="180" as="geometry" />
        </mxCell>
        <mxCell id="service-label" value="核心服务层" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontStyle=1;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="410" y="385" width="100" height="20" as="geometry" />
        </mxCell>

        <!-- Room Service -->
        <mxCell id="room-svc" value="房间服务" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="430" y="420" width="100" height="60" as="geometry" />
        </mxCell>

        <!-- User Service -->
        <mxCell id="user-svc" value="用户服务" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="550" y="420" width="100" height="60" as="geometry" />
        </mxCell>

        <!-- Voice Service -->
        <mxCell id="voice-svc" value="语音服务" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="670" y="420" width="100" height="60" as="geometry" />
        </mxCell>

        <!-- AI Service -->
        <mxCell id="ai-svc" value="AI 服务" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1f5fe;strokeColor=#0288d1;" vertex="1" parent="1">
          <mxGeometry x="430" y="500" width="340" height="40" as="geometry" />
        </mxCell>

        <!-- Data Layer -->
        <mxCell id="data-bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f3e5f5;strokeColor=#7b1fa2;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="850" y="50" width="200" height="300" as="geometry" />
        </mxCell>
        <mxCell id="data-label" value="数据层" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontStyle=1;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="860" y="55" width="80" height="20" as="geometry" />
        </mxCell>

        <!-- PostgreSQL -->
        <mxCell id="postgres" value="PostgreSQL&#xa;(用户/房间数据)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="870" y="90" width="160" height="60" as="geometry" />
        </mxCell>

        <!-- Redis -->
        <mxCell id="redis" value="Redis&#xa;(缓存/会话)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="870" y="180" width="160" height="60" as="geometry" />
        </mxCell>

        <!-- AI Models -->
        <mxCell id="models-bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e0f7fa;strokeColor=#00796b;dashed=1;" vertex="1" parent="1">
