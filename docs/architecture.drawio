        </mxCell>
        <mxCell id="models-label" value="AI 模型" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontStyle=1;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="860" y="385" width="80" height="20" as="geometry" />
        </mxCell>

        <!-- Paraformer ASR -->
        <mxCell id="asr" value="Paraformer&#xa;(ASR 语音识别)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="870" y="420" width="160" height="60" as="geometry" />
        </mxCell>

        <!-- Kokoro TTS -->
        <mxCell id="tts" value="Kokoro&#xa;(TTS 语音合成)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="870" y="500" width="160" height="60" as="geometry" />
        </mxCell>

        <!-- External Services -->
        <mxCell id="ext-bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffebee;strokeColor=#d32f2f;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="50" y="380" width="280" height="180" as="geometry" />
        </mxCell>
        <mxCell id="ext-label" value="外部服务" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontStyle=1;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="60" y="385" width="80" height="20" as="geometry" />
        </mxCell>

        <!-- LLM -->
        <mxCell id="llm" value="LLM API&#xa;(OpenRouter)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1f5fe;strokeColor=#0288d1;" vertex="1" parent="1">
          <mxGeometry x="80" y="420" width="110" height="60" as="geometry" />
        </mxCell>

        <!-- OAuth Providers -->
        <mxCell id="oauth" value="OAuth2&#xa;(GitHub/Google)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fce4ec;strokeColor=#c2185b;" vertex="1" parent="1">
          <mxGeometry x="210" y="420" width="100" height="60" as="geometry" />
        </mxCell>

        <!-- STUN/TURN -->
        <mxCell id="stun" value="STUN/TURN&#xa;(WebRTC穿透)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff3e0;strokeColor=#ff9800;" vertex="1" parent="1">
          <mxGeometry x="80" y="500" width="230" height="50" as="geometry" />
        </mxCell>

        <!-- Connections -->
        <mxCell id="conn1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#666666;" edge="1" parent="1" source="browser" target="nginx">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="conn2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#666666;" edge="1" parent="1" source="webrtc" target="nginx">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="conn3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#666666;" edge="1" parent="1" source="mobile" target="nginx">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="conn4" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#666666;" edge="1" parent="1" source="nginx" target="http-api">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="conn5" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#666666;" edge="1" parent="1" source="nginx" target="websocket">
          <mxGeometry relative="1" as="geometry" />
