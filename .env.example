# Voice Server 环境变量配置
# 复制此文件为 .env 并填入实际值
# cp .env.example .env

# ============ 服务器配置 ============
SERVER_HOST=0.0.0.0
SERVER_PORT=8080

# ============ HTTP API 配置 ============
HTTP_PORT=8080
HTTP_READ_TIMEOUT=30
HTTP_WRITE_TIMEOUT=30

# ============ WebSocket 配置 ============
WS_PORT=8081
WS_READ_TIMEOUT=60
WS_WRITE_TIMEOUT=60

# ============ Signaling 服务配置 ============
SIGNALING_PORT=8082

# ============ 数据库配置 ============
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_secure_password_here
DB_NAME=voicechat
DB_SSLMODE=disable

# ============ Redis 配置 ============
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ============ JWT 配置 ============
# 使用 openssl rand -base64 32 生成随机密钥
JWT_SECRET=your_jwt_secret_here_change_in_production
JWT_EXPIRATION=86400

# ============ OAuth2 配置 (可选) ============
# GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:8080/api/v1/auth/callback/github

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:8080/api/v1/auth/callback/google

# ============ LLM 配置 ============
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_API_KEY=your_api_key_here
LLM_MODEL=minimax/minimax-m2.5:free
LLM_MAX_TOKENS=2048
LLM_TEMPERATURE=70
LLM_SYSTEM_PROMPT=You are a helpful AI assistant.

# ============ 语音模型配置 ============
# ASR 模型路径 (Paraformer)
ASR_ENCODER_PATH=./models/paraformer/sherpa-onnx-streaming-paraformer-bilingual-zh-en/encoder.onnx
ASR_DECODER_PATH=./models/paraformer/sherpa-onnx-streaming-paraformer-bilingual-zh-en/decoder.onnx
ASR_TOKENS_PATH=./models/paraformer/sherpa-onnx-streaming-paraformer-bilingual-zh-en/tokens.txt

# TTS 模型路径 (Kokoro)
TTS_MODEL_PATH=./models/kokoro/kokoro-en-v0_19/model.onnx
TTS_VOICES_PATH=./models/kokoro/kokoro-en-v0_19/voices.bin
TTS_TOKENS_PATH=./models/kokoro/kokoro-en-v0_19/tokens.txt
TTS_DATA_DIR=./models/kokoro/kokoro-en-v0_19/espeak-ng-data

# 音频采样率
VOICE_SAMPLE_RATE=16000

# ============ 日志配置 ============
LOG_LEVEL=INFO
TZ=Asia/Shanghai
